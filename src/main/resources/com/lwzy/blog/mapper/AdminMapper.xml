<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lwzy.blog.mapper.AdminMapper">
    <select id="selectByUserNameAndPwd" resultType="Admin">
        select *
         from t_admin
        where username=#{username} and password=#{password}
    </select>

    <select id="selectById" resultType="Admin">
        select *
        from t_admin
        where id=#{id}
    </select>

    <update id="update">
        update t_admin
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password!= null and password!=''">
                password = #{password},
            </if>
            <if test="nickname!= null and nickname!=''">
                nickname = #{nickname},
            </if>
            <if test="sign!= null and sign!=''">
                sign = #{sign},
            </if>
            <!-- 更新时间总是更新 -->
            update_time = now(),
        </set>
        where id = #{id}
    </update>
</mapper>